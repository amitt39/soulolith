<!doctype html>
<html lang='{{ request.locale.iso_code }}'>
  <head>
    <meta charset='UTF-8'>
    <meta name='viewport' content='width=device-width, initial-scale=1.0'>
    <meta name='theme-color' content='#080706'>
    <link
      rel='icon'
      type='image/png'
      href='https://cdn.shopify.com/s/files/1/0816/7063/5763/files/soullith-favicon-bold.png?v=1776959125'
    >
    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>
    {%- if page_description -%}
      <meta name='description' content='{{ page_description | escape }}'>
    {%- endif -%}
    {{ content_for_header }}
    <link rel='preconnect' href='https://fonts.googleapis.com'>
    <link rel='preconnect' href='https://fonts.gstatic.com' crossorigin>
    <link
      href='https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Jost:wght@200;300;400;500&display=swap'
      rel='stylesheet'
    >
    {{ 'soullith.css' | asset_url | stylesheet_tag }}
  </head>
  <body>
    <header class='sl-site-header' id='sl-site-header'>
      {% assign hide_bar = false %}

      {% if request.page_type == 'product' and settings.hide_announcement_product %}
        {% assign hide_bar = true %}
      {% endif %}

      {% if request.page_type == 'cart' and settings.hide_announcement_cart %}
        {% assign hide_bar = true %}
      {% endif %}

      {% if settings.announcement_enabled and hide_bar == false %}
        <div class='sl-announcement-bar' id='sl-announcement-bar'>
          <span class='sl-announcement-text'>
            {{ settings.announcement_text }}
          </span>

          <button
            class='sl-announcement-close'
            id='sl-announcement-close'
            type='button'
            aria-label='Dismiss'
          >
            &times;
          </button>
        </div>
      {% endif %}
      <div class='sl-main-header'>
        <div class='sl-nav-container'>
          <div class='sl-nav-row-1'>
            <div class='sl-nav-left'>
              <button id='sl-search-trigger' class='sl-search-btn' aria-label='Search' type='button'>
                <svg
                  width='18'
                  height='18'
                  viewBox='0 0 24 24'
                  fill='none'
                  stroke='currentColor'
                  stroke-width='1.5'
                  stroke-linecap='round'
                  stroke-linejoin='round'
                >
                  <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                </svg>
              </button>
              <button class='sl-hamburger-btn' id='sl-mobile-open' type='button' aria-label='Open menu'>
                <span></span><span></span><span></span>
              </button>
            </div>
            <a href='{{ routes.root_url }}' class='sl-logo'>
              <img
                src='https://cdn.shopify.com/s/files/1/0816/7063/5763/files/soullith-header-logo-final.png?v=1777018881'
                alt='Soulolith'
                class='sl-logo-img'
                width='160'
                height='auto'
              >
            </a>
            <div class='sl-nav-right'>
              <button id='sl-search-trigger-mobile' class='sl-search-btn' aria-label='Search' type='button'>
                <svg
                  width='18'
                  height='18'
                  viewBox='0 0 24 24'
                  fill='none'
                  stroke='currentColor'
                  stroke-width='1.5'
                  stroke-linecap='round'
                  stroke-linejoin='round'
                >
                  <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                </svg>
              </button>
              <a href='{{ routes.cart_url }}' class='sl-nav-link-top sl-cart-link'>
                <svg
                  width='20'
                  height='20'
                  viewBox='0 0 24 24'
                  fill='none'
                  stroke='currentColor'
                  stroke-width='1.5'
                  stroke-linecap='round'
                  stroke-linejoin='round'
                >
                  <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/>
                </svg>
                <span class='sl-cart-count'>{{ cart.item_count }}</span>
              </a>
            </div>
          </div>

          {%- comment -%} ═══ BLOCK A — Replace <nav class="sl-nav-row-2"> ═══ {%- endcomment -%}

          <nav class='sl-nav-row-2' id='sl-desktop-nav' aria-label='Main navigation'>
            {%- comment -%} SHOP — direct link to all products {%- endcomment -%}
            <a
              href='{{ routes.collections_url }}/all'
              class='sl-nav-link-main{% if request.path == '/collections/all' %} active{% endif %}'
            >
              SHOP
            </a>

            {%- comment -%} BY CATEGORY — grouped mega menu {%- endcomment -%}
            <div class='sl-nav-item' data-mega='category'>
              <button class='sl-nav-link-main sl-nav-trigger' aria-expanded='false' aria-haspopup='true' type='button'>
                BY CATEGORY
                <svg class='sl-nav-chevron' width='10' height='6' viewBox='0 0 10 6' fill='none' aria-hidden='true'>
                  <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            </div>

            {%- comment -%} BY MEANING — multi-column mega menu {%- endcomment -%}
            <div class='sl-nav-item' data-mega='meaning'>
              <button class='sl-nav-link-main sl-nav-trigger' aria-expanded='false' aria-haspopup='true' type='button'>
                BY MEANING
                <svg class='sl-nav-chevron' width='10' height='6' viewBox='0 0 10 6' fill='none' aria-hidden='true'>
                  <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            </div>

            {%- comment -%} BY CRYSTALS — wide multi-column mega menu {%- endcomment -%}
            <div class='sl-nav-item' data-mega='crystals'>
              <button class='sl-nav-link-main sl-nav-trigger' aria-expanded='false' aria-haspopup='true' type='button'>
                BY CRYSTALS
                <svg class='sl-nav-chevron' width='10' height='6' viewBox='0 0 10 6' fill='none' aria-hidden='true'>
                  <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            </div>

            <div class='sl-nav-item' data-mega='zodiac'>
              <button class='sl-nav-link-main sl-nav-trigger' aria-expanded='false' aria-haspopup='true' type='button'>
                BY ZODIAC
                <svg class='sl-nav-chevron' width='10' height='6' viewBox='0 0 10 6' fill='none' aria-hidden='true'>
                  <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            </div>

            <div class='sl-nav-item' data-mega='home-decor'>
              <button class='sl-nav-link-main sl-nav-trigger' aria-expanded='false' aria-haspopup='true' type='button'>
                HOME DECOR
                <svg class='sl-nav-chevron' width='10' height='6' viewBox='0 0 10 6' fill='none' aria-hidden='true'>
                  <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            </div>

            <div class='sl-nav-item' data-mega='jewellery'>
              <button class='sl-nav-link-main sl-nav-trigger' aria-expanded='false' aria-haspopup='true' type='button'>
                JEWELLERY
                <svg class='sl-nav-chevron' width='10' height='6' viewBox='0 0 10 6' fill='none' aria-hidden='true'>
                  <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            </div>

            <div class='sl-nav-item' data-mega='gifting'>
              <button class='sl-nav-link-main sl-nav-trigger' aria-expanded='false' aria-haspopup='true' type='button'>
                GIFTING
                <svg class='sl-nav-chevron' width='10' height='6' viewBox='0 0 10 6' fill='none' aria-hidden='true'>
                  <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            </div>

            <a
              href='{{ routes.root_url }}pages/our-story'
              class='sl-nav-link-main{% if request.path contains 'our-story' %} active{% endif %}'
            >
              OUR STORY
            </a>
          </nav>
        </div>

        {%- comment -%} ═══ BLOCK B — Paste inside .sl-main-header, after </div> of .sl-nav-container ═══ {%- endcomment -%}

        {%- comment -%} BY CATEGORY MEGA PANEL — grouped: Spiritual, Meditation, Vastu, Wellness {%- endcomment -%}
        <div class='sl-mega-panel' data-panel='category' role='region' aria-label='Browse by category'>
          <div class='sl-mega-panel-inner sl-mega-category-grid'>
            {%- assign sl_cat_keys = 'spiritual,meditation,vastu,wellness' | split: ',' -%}
            {%- assign sl_cat_labels = 'Spiritual,Meditation & Tools,Vastu & Protection,Wellness' | split: ',' -%}
            {%- for sl_group in sl_cat_keys -%}
              {%- assign sl_list_handle = 'nav-category-' | append: sl_group -%}
              {%- assign sl_group_list = linklists[sl_list_handle] -%}
              {%- if sl_group_list.links.size > 0 -%}
                <div class='sl-mega-group'>
                  <p class='sl-mega-group-title'>{{ sl_cat_labels[forloop.index0] }}</p>
                  {%- for link in sl_group_list.links -%}
                    <a href='{{ link.url }}' class='sl-mega-link{% if link.active %} active{% endif %}'>
                      {{- link.title -}}
                    </a>
                  {%- endfor -%}
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>

        {%- comment -%} BY MEANING MEGA PANEL — 3-column CSS flow {%- endcomment -%}
        <div class='sl-mega-panel' data-panel='meaning' role='region' aria-label='Browse by meaning'>
          <div class='sl-mega-panel-inner'>
            <div class='sl-mega-flow sl-mega-flow--3'>
              {%- for link in linklists['nav-by-meaning'].links -%}
                <a href='{{ link.url }}' class='sl-mega-link{% if link.active %} active{% endif %}'>{{ link.title }}</a>
              {%- else -%}
                <p class='sl-mega-empty'>Add links to the <em>nav-by-meaning</em> menu in Navigation settings.</p>
              {%- endfor -%}
            </div>
          </div>
        </div>

        {%- comment -%} BY CRYSTALS MEGA PANEL — 5-column CSS flow {%- endcomment -%}
        <div class='sl-mega-panel' data-panel='crystals' role='region' aria-label='Browse by crystal'>
          <div class='sl-mega-panel-inner'>
            <div class='sl-mega-flow sl-mega-flow--5'>
              {%- for link in linklists['nav-by-crystals'].links -%}
                <a href='{{ link.url }}' class='sl-mega-link{% if link.active %} active{% endif %}'>{{ link.title }}</a>
              {%- else -%}
                <p class='sl-mega-empty'>Add links to the <em>nav-by-crystals</em> menu in Navigation settings.</p>
              {%- endfor -%}
            </div>
          </div>
        </div>
        <div class='sl-mega-panel' data-panel='zodiac' role='region' aria-label='Browse Zodiac'>
          <div class='sl-mega-panel-inner'>
            <div class='sl-mega-flow sl-mega-flow--3'>
              {%- for link in linklists['nav-by-zodiac'].links -%}
                <a href='{{ link.url }}' class='sl-mega-link{% if link.active %} active{% endif %}'>
                  {{ link.title }}
                </a>
              {%- endfor -%}
            </div>
          </div>
        </div>
        <div class='sl-mega-panel' data-panel='home-decor' role='region' aria-label='Browse Home Decor'>
          <div class='sl-mega-panel-inner'>
            <div class='sl-mega-flow sl-mega-flow--4'>
              {%- for link in linklists['nav-home-decor'].links -%}
                <a href='{{ link.url }}' class='sl-mega-link{% if link.active %} active{% endif %}'>{{ link.title }}</a>
              {%- endfor -%}
            </div>
          </div>
        </div>

        <div class='sl-mega-panel' data-panel='jewellery' role='region' aria-label='Browse Jewellery'>
          <div class='sl-mega-panel-inner'>
            <div class='sl-mega-flow sl-mega-flow--3'>
              {%- for link in linklists['nav-jewellery'].links -%}
                <a href='{{ link.url }}' class='sl-mega-link{% if link.active %} active{% endif %}'>{{ link.title }}</a>
              {%- endfor -%}
            </div>
          </div>
        </div>

        <div class='sl-mega-panel' data-panel='gifting' role='region' aria-label='Browse Gifting'>
          <div class='sl-mega-panel-inner'>
            <div class='sl-mega-flow sl-mega-flow--2'>
              {%- for link in linklists['nav-gifting'].links -%}
                <a href='{{ link.url }}' class='sl-mega-link{% if link.active %} active{% endif %}'>{{ link.title }}</a>
              {%- endfor -%}
            </div>
          </div>
        </div>
      </div>
      <div class='sl-menu-overlay-dim' id='sl-dim-overlay'></div>
      {%- comment -%} ═══ BLOCK C — Replace <nav class="sl-mobile-menu"> ═══ {%- endcomment -%}

      <nav class='sl-mobile-menu' id='sl-mobile-nav' aria-label='Mobile navigation'>
        <div class='sl-mob-header'>
          <a href='{{ routes.root_url }}' class='sl-mob-brand'>
            <img
              src='https://cdn.shopify.com/s/files/1/0816/7063/5763/files/soullith-header-logo-final.png?v=1777018881'
              alt='Soulolith'
              style='width: 120px; height: auto; display: block;'
              height=''
              width=''
            >
          </a>
          <button class='sl-mobile-nav-close' id='sl-mobile-close' aria-label='Close menu' type='button'>
            &times;
          </button>
        </div>

        <div class='sl-mob-links'>
          {%- comment -%} SHOP — direct link {%- endcomment -%}
          <a href='{{ routes.collections_url }}/all' class='sl-mob-link-main'>Shop All</a>

          {%- comment -%} BY CATEGORY — accordion with groups {%- endcomment -%}
          <div class='sl-mob-accordion'>
            <button class='sl-mob-link-main sl-mob-trigger' aria-expanded='false' type='button'>
              By Category
              <svg class='sl-mob-chevron' width='12' height='8' viewBox='0 0 10 6' fill='none' aria-hidden='true'>
                <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class='sl-mob-panel' hidden>
              {%- assign sl_cat_keys = 'spiritual,meditation,vastu,wellness' | split: ',' -%}
              {%- assign sl_cat_labels = 'Spiritual,Meditation & Tools,Vastu & Protection,Wellness' | split: ',' -%}
              {%- for sl_group in sl_cat_keys -%}
                {%- assign sl_list_handle = 'nav-category-' | append: sl_group -%}
                {%- assign sl_group_list = linklists[sl_list_handle] -%}
                {%- if sl_group_list.links.size > 0 -%}
                  <p class='sl-mob-group-label'>{{ sl_cat_labels[forloop.index0] }}</p>
                  {%- for link in sl_group_list.links -%}
                    <a href='{{ link.url }}' class='sl-mob-sub-link'>{{ link.title }}</a>
                  {%- endfor -%}
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>

          {%- comment -%} BY MEANING — accordion {%- endcomment -%}
          <div class='sl-mob-accordion'>
            <button class='sl-mob-link-main sl-mob-trigger' aria-expanded='false' type='button'>
              By Meaning
              <svg class='sl-mob-chevron' width='12' height='8' viewBox='0 0 10 6' fill='none' aria-hidden='true'>
                <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class='sl-mob-panel' hidden>
              {%- for link in linklists['nav-by-meaning'].links -%}
                <a href='{{ link.url }}' class='sl-mob-sub-link'>{{ link.title }}</a>
              {%- endfor -%}
            </div>
          </div>

          {%- comment -%} BY CRYSTALS — accordion {%- endcomment -%}
          <div class='sl-mob-accordion'>
            <button class='sl-mob-link-main sl-mob-trigger' aria-expanded='false' type='button'>
              By Crystals
              <svg class='sl-mob-chevron' width='12' height='8' viewBox='0 0 10 6' fill='none' aria-hidden='true'>
                <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class='sl-mob-panel' hidden>
              {%- for link in linklists['nav-by-crystals'].links -%}
                <a href='{{ link.url }}' class='sl-mob-sub-link'>{{ link.title }}</a>
              {%- endfor -%}
            </div>
          </div>

          <div class='sl-mob-accordion'>
            <button class='sl-mob-link-main sl-mob-trigger' aria-expanded='false' type='button'>
              By Zodiac
              <svg class='sl-mob-chevron' width='12' height='8' viewBox='0 0 10 6' fill='none' aria-hidden='true'>
                <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>

            <div class='sl-mob-panel' hidden>
              {%- for link in linklists['nav-by-zodiac'].links -%}
                <a href='{{ link.url }}' class='sl-mob-sub-link'>
                  {{ link.title }}
                </a>
              {%- endfor -%}
            </div>
          </div>

          {%- comment -%} HOME DECOR — accordion {%- endcomment -%}
          <div class='sl-mob-accordion'>
            <button class='sl-mob-link-main sl-mob-trigger' aria-expanded='false' type='button'>
              Home Decor
              <svg class='sl-mob-chevron' width='12' height='8' viewBox='0 0 10 6' fill='none' aria-hidden='true'>
                <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class='sl-mob-panel' hidden>
              {%- for link in linklists['nav-home-decor'].links -%}
                <a href='{{ link.url }}' class='sl-mob-sub-link'>{{ link.title }}</a>
              {%- endfor -%}
            </div>
          </div>

          {%- comment -%} JEWELLERY — accordion {%- endcomment -%}
          <div class='sl-mob-accordion'>
            <button class='sl-mob-link-main sl-mob-trigger' aria-expanded='false' type='button'>
              Jewellery
              <svg class='sl-mob-chevron' width='12' height='8' viewBox='0 0 10 6' fill='none' aria-hidden='true'>
                <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class='sl-mob-panel' hidden>
              {%- for link in linklists['nav-jewellery'].links -%}
                <a href='{{ link.url }}' class='sl-mob-sub-link'>{{ link.title }}</a>
              {%- endfor -%}
            </div>
          </div>

          {%- comment -%} GIFTING — accordion {%- endcomment -%}
          <div class='sl-mob-accordion'>
            <button class='sl-mob-link-main sl-mob-trigger' aria-expanded='false' type='button'>
              Gifting
              <svg class='sl-mob-chevron' width='12' height='8' viewBox='0 0 10 6' fill='none' aria-hidden='true'>
                <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class='sl-mob-panel' hidden>
              {%- for link in linklists['nav-gifting'].links -%}
                <a href='{{ link.url }}' class='sl-mob-sub-link'>{{ link.title }}</a>
              {%- endfor -%}
            </div>
          </div>

          {%- comment -%} Static bottom links {%- endcomment -%}
          <div class='sl-mob-divider'></div>
          <a href='{{ routes.root_url }}pages/our-story' class='sl-mob-link-main sl-mob-link-secondary'>Our Story</a>
          <a href='{{ routes.root_url }}pages/contact' class='sl-mob-link-main sl-mob-link-secondary'>Contact</a>
        </div>
      </nav>

      <div id='sl-search-overlay' class='sl-search-overlay' aria-hidden='true'>
        <div class='sl-search-overlay-inner'>
          <div class='sl-search-input-row'>
            <svg
              width='20'
              height='20'
              viewBox='0 0 24 24'
              fill='none'
              stroke='currentColor'
              stroke-width='1.5'
              stroke-linecap='round'
              stroke-linejoin='round'
              style='flex-shrink:0;color:var(--text-muted)'
            >
              <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <input
              id='sl-search-input'
              class='sl-search-input'
              type='search'
              placeholder='Search crystals, intentions, stones...'
              autocomplete='off'
              spellcheck='false'
            >
            <button id='sl-search-close' class='sl-search-close' aria-label='Close search' type='button'>
              &times;
            </button>
          </div>
          <p id='sl-search-hint' class='sl-search-hint'>Try: amethyst, love, protection, bracelet…</p>
          <div id='sl-search-results' class='sl-search-results'></div>
        </div>
      </div>
      <div id='sl-stock-toast'></div>
    </header>

    <main id='MainContent' class='sl-main-content' role='main' tabindex='-1'>
      {{ content_for_layout }}
    </main>

    <footer class='sl-footer' role='contentinfo'>
      <div class='sl-container'>
        <div class='sl-footer-grid'>
          <div class='sl-footer-col-1'>
            <a href='{{ routes.root_url }}' class='sl-footer-brand-logo'>
              <img
                src='https://cdn.shopify.com/s/files/1/0816/7063/5763/files/soullith-header-logo-final.png?v=1777018881'
                alt='SOULOLITH'
                loading='lazy'
                width='140'
                height=''
              >
            </a>
            <p>
              Luxury crystal jewelry and spiritual décor handcrafted with intention. Each piece is ethically sourced and
              energetically selected.
            </p>
            <div class='sl-social-icons'>
              {%- if settings.social_instagram_link != blank -%}
                <a
                  href='{{ settings.social_instagram_link }}'
                  class='sl-social-icon'
                  target='_blank'
                  rel='noopener'
                  aria-label='Instagram'
                >
                  <svg width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.8'>
                    <rect x="2" y="2" width="20" height="20" rx="5"></rect>
                    <circle cx="12" cy="12" r="4"></circle>
                    <circle cx="18" cy="6" r="1"></circle>
                  </svg>
                </a>
              {%- endif -%}

              {%- if settings.social_facebook_link != blank -%}
                <a
                  href='{{ settings.social_facebook_link }}'
                  class='sl-social-icon'
                  target='_blank'
                  rel='noopener'
                  aria-label='Facebook'
                >
                  <svg width='18' height='18' viewBox='0 0 24 24' fill='currentColor'>
