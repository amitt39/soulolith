<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ shop.name }} — Coming Soon</title>
  {{ content_for_header }}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&family=Jost:wght@300;400&display=swap" rel="stylesheet">
  {{ 'soullith.css' | asset_url | stylesheet_tag }}
  <style>
    body { display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100vh; text-align: center; padding: 40px 24px; }
    .sl-password-logo { font-family: 'Cormorant Garamond', serif; font-size: 28px; font-weight: 500; letter-spacing: 6px; color: var(--text); margin-bottom: 48px; }
    .sl-password-logo span { color: var(--rose); }
    .sl-password-box { max-width: 420px; width: 100%; }
    .sl-password-box h1 { font-size: clamp(32px, 5vw, 56px); font-weight: 300; margin-bottom: 16px; }
    .sl-password-box p { color: var(--text-muted); font-size: 13px; line-height: 1.7; margin-bottom: 36px; }
  </style>
</head>
<body>
  <div class="sl-password-logo">SOUL <span>◇</span> LITH</div>
  <div class="sl-password-box">
    {{ content_for_layout }}
  </div>
</body>
</html>
