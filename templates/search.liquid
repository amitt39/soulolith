{% comment %}
  Soulolith — Search Page
  File: templates/search.liquid
{% endcomment %}

<section class="sl-shop-hero">
  <div class="sl-container">
    <span class="sl-eyebrow">
      {%- if search.performed -%}
        {{ search.results_count }} result{% if search.results_count != 1 %}s{% endif %} for "{{ search.terms | escape }}"
      {%- else -%}
        Search
      {%- endif -%}
    </span>
    <h1>Find Your <em>Crystal</em></h1>
    <form action="{{ routes.search_url }}" method="get" style="max-width:480px;margin:32px auto 0;">
      <div class="sl-newsletter-form">
        <input type="search"
               name="q"
               class="sl-form-input"
               value="{{ search.terms | escape }}"
               placeholder="Search crystals, jewelry..."
               aria-label="Search"
               autocomplete="off">
        <button type="submit" class="sl-btn-primary">Search</button>
      </div>
    </form>
  </div>
</section>

{%- if search.performed -%}
  <div class="sl-container" style="padding: 60px 24px;">
    {%- if search.results_count > 0 -%}
      <div class="sl-shop-product-grid">
        {%- for result in search.results -%}
          {%- if result.object_type == 'product' -%}
            <a href="{{ result.url }}" class="sl-product-card">
              <div class="sl-product-image-wrapper">
                {%- if result.featured_image != blank -%}
                  <img src="{{ result.featured_image | image_url: width: 600 }}"
                       alt="{{ result.featured_image.alt | escape }}"
                       loading="lazy" width="600">
                {%- else -%}
                  <div style="width:100%;height:100%;background:linear-gradient(135deg,#2a1520,#3d2030);"></div>
                {%- endif -%}
                <div class="sl-product-hover-overlay">
                  <span class="sl-btn-primary">View Product</span>
                </div>
              </div>
              <div class="sl-product-info">
                {%- if result.type != blank -%}
                  <div class="sl-product-stone">{{ result.type }}</div>
                {%- endif -%}
                <h3 class="sl-product-name">{{ result.title }}</h3>
                <div class="sl-product-price">{{ result.price | money }}</div>
              </div>
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- else -%}
      <div style="text-align:center;padding:80px 0;">
        <div style="font-size:64px;color:rgba(240,234,224,0.06);margin-bottom:24px;">◇</div>
        <h2 style="font-size:32px;font-weight:300;margin-bottom:16px;">No results for "<em>{{ search.terms | escape }}</em>"</h2>
        <p style="color:var(--text-muted);margin-bottom:40px;">Try a different crystal name, stone type, or intention.</p>
        <a href="{{ routes.collections_url }}/all" class="sl-btn-outline">Browse All Products</a>
      </div>
    {%- endif -%}
  </div>
{%- endif -%}
