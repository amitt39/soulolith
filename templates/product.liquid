    .sl-product-thumb {
      width: calc(20% - 7px);
    }
  }

  #wishlisthero-product-page-button-container {
    display: none !important;
  }
</style>

<script>
  (function(){
    var productData = {{ product.variants | json }};
    var swatches    = document.querySelectorAll('.sl-option-swatch');
    var priceBlock  = document.getElementById('sl-price-block');
    var variantIdEl = document.getElementById('sl-variant-id');
    var addBtn      = document.getElementById('sl-main-atc');
    var stickyBar   = document.getElementById('sl-sticky-atc');
    var stickyBtn   = document.getElementById('sl-sticky-atc-btn');
    var stickyPrice = document.getElementById('sl-sticky-price');
    var mainForm    = document.getElementById('sl-product-form');
    var thumbs      = document.querySelectorAll('.sl-product-thumb');
    var mainImg     = document.getElementById('sl-main-product-image');
    var imgCurrent  = document.getElementById('sl-img-current');

    function formatPrice(cents) {
      return '₹' + Math.round(cents / 100).toLocaleString('en-IN');
    }

    function updateUI(variant) {
      if (!variant) return;
      variantIdEl.value = variant.id;
      var price = formatPrice(variant.price);
      var comp  = variant.compare_at_price;
      if (comp > variant.price) {
        var pct = Math.round((comp - variant.price) / comp * 100);
        priceBlock.innerHTML =
          '<span class="sl-original-price">' + formatPrice(comp) + '</span>' +
          '<span class="sl-sale-price">' + price + '</span>' +
          '<span class="sl-savings-badge">Save ' + pct + '%</span>';
      } else {
        priceBlock.innerHTML = '<span class="sl-sale-price">' + price + '</span>';
      }
      if (addBtn) {
        addBtn.textContent = variant.available ? 'Add to Cart — ' + price : 'Sold Out';
        addBtn.disabled = !variant.available;
        addBtn.classList.toggle('sl-btn--disabled', !variant.available);
      }
      if (stickyPrice) stickyPrice.textContent = price;
      if (stickyBtn) {
        stickyBtn.textContent = variant.available ? 'Add to Cart' : 'Sold Out';
        stickyBtn.disabled = !variant.available;
        stickyBtn.classList.toggle('sl-btn--disabled', !variant.available);
      }
    }

    function getSelectedOptions() {
      var opts = {};
      swatches.forEach(function(sw) {
        if (sw.classList.contains('active')) opts[sw.getAttribute('data-option-index')] = sw.getAttribute('data-value');
      });
      return opts;
    }

    /* ── Variant switcher ── */
    swatches.forEach(function(sw) {
      sw.addEventListener('click', function() {
        var idx = sw.getAttribute('data-option-index');
        document.querySelectorAll('[data-option-index="' + idx + '"]').forEach(function(s) { s.classList.remove('active'); });
        sw.classList.add('active');
        var variant = productData.find(function(v) {
          return v.options.every(function(opt, i) { return getSelectedOptions()[i] === opt; });
        });
        updateUI(variant);
      });
    });

    /* ── Thumbnail switcher ── */
    thumbs.forEach(function(thumb) {
      thumb.addEventListener('click', function() {
        thumbs.forEach(function(t) { t.classList.remove('active'); });
        thumb.classList.add('active');
        var src = thumb.getAttribute('data-src');
        if (src && mainImg) mainImg.src = src;
        if (imgCurrent) {
          var idx = thumb.getAttribute('data-index') || '1';
          imgCurrent.textContent = idx.toString().padStart(2, '0');
        }
      });
    });

    /* ── Intention picker ── */
    document.querySelectorAll('.sl-intention-option').forEach(function(btn) {
      btn.addEventListener('click', function() {
        document.querySelectorAll('.sl-intention-option').forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        var intention = btn.getAttribute('data-intention');
        var input = document.getElementById('sl-intention-input');
        var label = document.getElementById('sl-intention-label');
        if (input) input.value = intention;
        if (label) label.textContent = intention;
      });
    });

    /* ── Accordion ── */
    document.querySelectorAll('.sl-accordion-trigger').forEach(function(trigger) {
      trigger.addEventListener('click', function() {
        var targetId = trigger.getAttribute('data-target');
        var body = document.getElementById(targetId);
        var icon = trigger.querySelector('.sl-accordion-icon');
        var isOpen = body.classList.contains('is-open');
        body.classList.toggle('is-open', !isOpen);
        trigger.setAttribute('aria-expanded', !isOpen);
        if (icon) icon.textContent = isOpen ? '+' : '−';
      });
    });

    /* ── Sticky bar scroll ── */
    if (stickyBar && addBtn) {
      function checkSticky() {
        var rect = addBtn.getBoundingClientRect();
        var off  = rect.bottom < 0 || rect.top > window.innerHeight;
        stickyBar.classList.toggle('is-visible', off);
        document.body.classList.toggle('sl-sticky-visible', off);
      }
      window.addEventListener('scroll', checkSticky, { passive: true });
      checkSticky();
    }

    /* ── Qty buttons ── */
    document.querySelectorAll('.sl-cart-qty:not([data-cart-handled])').forEach(function(widget) {
      var input = widget.querySelector('input');
      widget.querySelectorAll('button').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var delta = btn.getAttribute('data-action') === 'minus' ? -1 : 1;
          input.value = Math.max(1, (parseInt(input.value, 10) || 1) + delta);
        });
      });
    });

    /* ── Sticky ATC click ── */
    if (stickyBtn && mainForm) {
      stickyBtn.addEventListener('click', function() {
        if (stickyBtn.disabled) return;
        stickyBtn.textContent = 'Adding...';
        stickyBtn.disabled = true;
        fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams(new FormData(mainForm))
        })
        .then(function(r) { return r.json(); })
        .then(function() {
          stickyBtn.textContent = '✓ Added!';
          stickyBtn.classList.add('is-added');
          fetch('/cart.js').then(function(r) { return r.json(); }).then(function(cart) {
            document.querySelectorAll('.sl-cart-count').forEach(function(b) {
              b.textContent = cart.item_count;
              b.style.display = cart.item_count > 0 ? 'flex' : 'none';
            });
          });
          setTimeout(function() {
            stickyBtn.textContent = 'View Cart';
            stickyBtn.classList.remove('is-added');
            stickyBtn.disabled = false;
            stickyBtn.onclick = function() { window.location.href = '/cart'; };
          }, 1500);
        })
        .catch(function() {
          stickyBtn.textContent = 'Add to Cart';
          stickyBtn.disabled = false;
        });
      });
    }
  })();
</script>
