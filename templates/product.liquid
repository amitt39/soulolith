  }
  .sl-sticky-atc-price {
    font-family: 'Jost', sans-serif;
    font-size: 13px;
    color: var(--rose-light);
  }
  .sl-sticky-atc-btn {
    flex-shrink: 0;
    padding: 13px 28px;
    background: var(--rose);
    border: 1px solid var(--rose);
    color: #080706;
    font-family: 'Jost', sans-serif;
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.25s, border-color 0.25s, color 0.25s;
    white-space: nowrap;
  }
  .sl-sticky-atc-btn:hover:not(:disabled) {
    background: var(--rose-dark);
    border-color: var(--rose-dark);
    color: var(--text);
  }
  .sl-sticky-atc-btn.is-added {
    background: var(--rose-dark);
    color: var(--text);
  }

  body.sl-sticky-visible .wishlist-hero--floating-launcher,
  body.sl-sticky-visible [id*='wishlist-hero-floating'],
  body.sl-sticky-visible [class*='floating-launcher'] {
    bottom: 70px !important;
    transition: bottom 0.35s cubic-bezier(0.4, 0, 0.2, 1) !important;
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .sl-product-layout {
      grid-template-columns: 1fr;
      gap: 20px;
      padding: 20px 0 80px;
    }
    .sl-product-gallery {
      position: static;
    }
    /* Mobile: no forced aspect ratio — show full image */
    .sl-product-main-image {
      aspect-ratio: unset;
      max-height: none;
      overflow: visible;
    }
    .sl-product-main-image img {
      width: 100%;
      height: auto;
      object-fit: contain;
    }
    .sl-product-title {
      font-size: clamp(18px, 5vw, 24px);
    }
    .sl-product-price-block .sl-sale-price {
      font-size: 30px;
    }
    .sl-qty-atc-row {
      grid-template-columns: auto 1fr 52px;
      gap: 8px;
    }
    .sl-wl-slot,
    .sl-wl-slot .wishlist-hero-custom-button {
      width: 52px !important;
      height: 52px !important;
    }
    .sl-sticky-atc {
      padding: 12px 16px;
    }
    .sl-sticky-atc-title {
      font-size: 12px;
    }
    .sl-sticky-atc-btn {
      padding: 12px 16px;
      font-size: 10px;
    }
    .sl-trust-badges-row .sl-trust-badge {
      font-size: 9px;
      padding: 10px 4px;
