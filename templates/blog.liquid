{% comment %}
  Soulolith — Blog Page
  File: templates/blog.liquid
{% endcomment %}

<section class="sl-section" style="padding-top: 60px;">
  <div class="sl-container">

    <div class="sl-section-header">
      <span class="sl-eyebrow">Crystal Wisdom</span>
      <h1 class="sl-section-title">{{ blog.title }}</h1>
      <div class="sl-divider"></div>
    </div>

    {%- paginate blog.articles by 9 -%}

      {%- if blog.articles.size > 0 -%}
        <div class="sl-blog-grid">
          {%- for article in blog.articles -%}
            <a href="{{ article.url }}" class="sl-blog-card">
              <div class="sl-blog-card-image">
                {%- if article.image != blank -%}
                  <img src="{{ article.image | image_url: width: 600 }}"
                       alt="{{ article.image.alt | escape }}"
                       loading="lazy" width="600">
                {%- else -%}
                  <div class="sl-blog-card-placeholder">✦</div>
                {%- endif -%}
              </div>
              <div class="sl-blog-card-info">
                <div class="sl-blog-card-meta">
                  <span>{{ article.published_at | date: '%B %d, %Y' }}</span>
                  {%- if article.tags.size > 0 -%}
                    <span>·</span>
                    <span>{{ article.tags | first }}</span>
                  {%- endif -%}
                </div>
                <h2 class="sl-blog-card-title">{{ article.title }}</h2>
                <p class="sl-blog-card-excerpt">{{ article.excerpt_or_content | strip_html | truncate: 120 }}</p>
                <span class="sl-blog-card-read">Read More →</span>
              </div>
            </a>
          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          <div class="sl-pagination" style="text-align:center;margin-top:48px;padding-bottom:80px;">
            {{ paginate | default_pagination }}
          </div>
        {%- endif -%}

      {%- else -%}
        <div style="text-align:center;padding:80px 0;">
          <p style="font-family:'Cormorant Garamond',serif;font-size:24px;color:var(--text-muted);">No posts yet — check back soon.</p>
        </div>
      {%- endif -%}

    {%- endpaginate -%}

  </div>
</section>

<style>
  .sl-blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    margin-bottom: 60px;
  }
  .sl-blog-card {
    display: flex; flex-direction: column;
    text-decoration: none; color: var(--text);
    border: 1px solid var(--border);
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }
  .sl-blog-card:hover {
    box-shadow: 0 8px 32px rgba(196,136,122,0.08);
    transform: translateY(-2px);
  }
  .sl-blog-card-image {
    aspect-ratio: 16/9; overflow: hidden; background: var(--bg-card);
  }
  .sl-blog-card-image img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.5s ease;
  }
  .sl-blog-card:hover .sl-blog-card-image img { transform: scale(1.04); }
  .sl-blog-card-placeholder {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    font-size: 32px; color: var(--rose-dark);
    background: linear-gradient(135deg, #1e0e14, #2e1520);
  }
  .sl-blog-card-info { padding: 24px; display: flex; flex-direction: column; gap: 10px; flex: 1; }
  .sl-blog-card-meta {
    font-family: 'Jost', sans-serif; font-size: 10px;
    letter-spacing: 2px; text-transform: uppercase;
    color: var(--rose); display: flex; gap: 8px;
  }
  .sl-blog-card-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 20px; font-weight: 400; line-height: 1.3;
    color: var(--text);
  }
  .sl-blog-card-excerpt {
    font-family: 'Jost', sans-serif; font-size: 13px;
    color: var(--text-muted); line-height: 1.7; flex: 1;
  }
  .sl-blog-card-read {
    font-family: 'Jost', sans-serif; font-size: 11px;
    letter-spacing: 1.5px; text-transform: uppercase;
    color: var(--rose-light); margin-top: 8px;
  }

  @media (max-width: 1024px) { .sl-blog-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 768px) { .sl-blog-grid { grid-template-columns: 1fr; gap: 20px; } }
</style>
