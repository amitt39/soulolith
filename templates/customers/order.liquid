{% comment %} Soulolith — Order Detail {% endcomment %}
<section class="sl-section" style="padding-top:60px;">
  <div class="sl-container" style="max-width:800px;">
    <div class="sl-section-header" style="text-align:left;">
      <span class="sl-eyebrow">Order {{ order.name }}</span>
      <h1 class="sl-section-title">Order <em>Details</em></h1>
      <div class="sl-divider" style="margin:0 0 32px;"></div>
    </div>
    <p style="font-size:12px;color:var(--text-muted);margin-bottom:32px;">Placed on {{ order.created_at | date: '%B %d, %Y' }} · Status: <span style="color:var(--rose-light);">{{ order.financial_status }}</span></p>
    {%- for line_item in order.line_items -%}
      <div style="display:grid;grid-template-columns:80px 1fr auto;gap:20px;align-items:center;padding:20px 0;border-bottom:1px solid var(--border);">
        <div style="background:var(--bg-card);border:1px solid var(--border);aspect-ratio:1/1;overflow:hidden;">
          {%- if line_item.image -%}
            <img src="{{ line_item.image | image_url: width: 160 }}" alt="{{ line_item.title | escape }}" width="160" style="width:100%;height:100%;object-fit:cover;">
          {%- endif -%}
        </div>
        <div>
          <p style="font-family:'Cormorant Garamond',serif;font-size:18px;font-weight:400;margin-bottom:4px;">{{ line_item.title }}</p>
          {%- unless line_item.variant.title == 'Default Title' -%}
            <p style="font-size:11px;color:var(--text-faint);letter-spacing:1px;">{{ line_item.variant.title }}</p>
          {%- endunless -%}
          <p style="font-size:12px;color:var(--text-muted);margin-top:4px;">Qty: {{ line_item.quantity }}</p>
        </div>
        <div style="color:var(--rose-light);font-size:14px;">{{ line_item.final_line_price | money }}</div>
      </div>
    {%- endfor -%}
    <div style="margin-top:32px;text-align:right;">
      <div style="display:flex;justify-content:flex-end;gap:40px;color:var(--text-muted);font-size:13px;margin-bottom:12px;">
        <span>Subtotal</span><span>{{ order.subtotal_price | money }}</span>
      </div>
      <div style="display:flex;justify-content:flex-end;gap:40px;font-size:16px;color:var(--text);border-top:1px solid var(--border);padding-top:16px;margin-top:16px;">
        <span>Total</span><span>{{ order.total_price | money }}</span>
      </div>
    </div>
    <div style="margin-top:40px;">
      <a href="{{ routes.account_url }}" class="sl-btn-outline">← Back to Account</a>
    </div>
  </div>
</section>
