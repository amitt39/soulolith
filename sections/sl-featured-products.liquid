{% comment %}
  Soulolith — Featured Products
  File: sections/sl-featured-products.liquid
  Pulls real products from a selected collection OR manually chosen products.
{% endcomment %}

{%- assign featured_collection = collections[section.settings.collection] -%}

<section class="sl-section sl-featured-section">
  <div class="sl-container">

    <div class="sl-section-header">
      <span class="sl-eyebrow">{{ section.settings.eyebrow | default: 'Handpicked for You' }}</span>
      <h2 class="sl-section-title">{{ section.settings.heading | default: 'Bestselling Pieces' }}</h2>
      <div class="sl-divider"></div>
    </div>

    <div class="sl-product-grid">

      {%- if featured_collection != blank and featured_collection.products.size > 0 -%}
        {%- for product in featured_collection.products limit: section.settings.product_count -%}
          {%- assign stone_tag = '' -%}
          {%- for tag in product.tags -%}
            {%- if tag contains 'stone:' -%}
              {%- assign stone_tag = tag | remove: 'stone:' | strip -%}
            {%- endif -%}
          {%- endfor -%}

          <div class="sl-product-card sl-product-card--featured">

            {%- comment %} Image — clickable link {%- endcomment %}
            <a href="{{ product.url }}" class="sl-product-image-wrapper sl-product-image-wrapper--square" aria-label="{{ product.title }}">
              {%- if product.featured_image != blank -%}
                <img src="{{ product.featured_image | image_url: width: 600 }}"
                     alt="{{ product.featured_image.alt | escape }}"
                     loading="lazy" width="600">
              {%- else -%}
                <div class="sl-product-placeholder"></div>
              {%- endif -%}

              {%- if product.tags contains 'badge:New' -%}
                <div class="sl-product-badge">New</div>
              {%- elsif product.tags contains 'badge:Bestseller' -%}
                <div class="sl-product-badge">Bestseller</div>
              {%- endif -%}

              <div class="sl-product-hover-overlay">
                <span class="sl-btn-primary sl-btn--sm">View Product</span>
              </div>
            </a>

            {%- comment %} Info {%- endcomment %}
            <div class="sl-product-info sl-product-info--featured">
              {%- if stone_tag != '' -%}
                <div class="sl-product-stone">{{ stone_tag }}</div>
              {%- elsif product.type != blank -%}
                <div class="sl-product-stone">{{ product.type }}</div>
              {%- endif -%}

              <a href="{{ product.url }}" class="sl-product-name-link">
                <h3 class="sl-product-name">{{ product.title }}</h3>
              </a>

              <div class="sl-product-price-row">
                <div class="sl-product-price">
                  {%- if product.compare_at_price > product.price -%}
                    <span class="sl-original-price">{{ product.compare_at_price | money_without_trailing_zeros }}</span>
                  {%- endif -%}
                  <span class="sl-sale-price">{{ product.price | money_without_trailing_zeros }}</span>
                </div>

                {%- if product.available -%}
                  <form action="{{ routes.cart_add_url }}" method="post" class="sl-atc-form">
                    <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                    <input type="hidden" name="quantity" value="1">
                    <button type="submit" class="sl-atc-btn" aria-label="Add {{ product.title }} to cart">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
                      Add to Cart
                    </button>
                  </form>
                {%- else -%}
                  <span class="sl-sold-out-label">Sold Out</span>
                {%- endif -%}
              </div>
            </div>

          </div>
        {%- endfor -%}

      {%- else -%}
        {%- comment %} Fallback placeholder cards {%- endcomment %}
        {%- for i in (1..3) -%}
          <div class="sl-product-card sl-product-card--featured">
            <a href="{{ routes.collections_url }}/all" class="sl-product-image-wrapper sl-product-image-wrapper--square">
              <div class="sl-product-placeholder"></div>
              <div class="sl-product-hover-overlay">
                <span class="sl-btn-primary sl-btn--sm">View Product</span>
              </div>
            </a>
            <div class="sl-product-info sl-product-info--featured">
              <div class="sl-product-stone">Crystal</div>
              <a href="{{ routes.collections_url }}/all" class="sl-product-name-link">
                <h3 class="sl-product-name">Sample Product</h3>
              </a>
              <div class="sl-product-price-row">
                <div class="sl-product-price">
                  <span class="sl-original-price">₹999</span>
                  <span class="sl-sale-price">₹799</span>
                </div>
                <button class="sl-atc-btn" disabled>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
                  Add to Cart
                </button>
              </div>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}

    </div><!-- /.sl-product-grid -->

    <div class="sl-all-products-link">
      <a href="{{ section.settings.cta_url | default: routes.collections_url | append: '/all' }}"
         class="sl-btn-outline">
        {{ section.settings.cta_label | default: 'View All Products' }}
      </a>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "SL Featured Products",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Handpicked for You"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Bestselling Pieces"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection to Feature"
    },
    {
      "type": "range",
      "id": "product_count",
      "min": 3,
      "max": 6,
      "step": 1,
      "label": "Number of Products",
      "default": 3
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA Button Label",
      "default": "View All Products"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA Button URL"
    }
  ],
  "presets": [
    {
      "name": "SL Featured Products"
    }
  ]
}
{% endschema %}

<style>
.sl-product-grid{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:24px;
}

@media screen and (max-width: 990px){
  .sl-product-grid{
    grid-template-columns:repeat(2,1fr);
  }
}

@media screen and (max-width: 768px){
  .sl-product-grid{
    grid-template-columns:1fr;
  }
}
</style>
