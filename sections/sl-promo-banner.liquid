{% comment %}
  Soulolith — Promo Banner Section
  File: sections/sl-promo-banner.liquid

  HOW TO USE (for Purnesh):
  1. Go to Online Store → Customize → Homepage
  2. Click "Add section" → select "SL Promo Banner"
  3. Fill in your offer text, button label and URL
  4. Save — banner appears on homepage
  5. To remove — click the section → Remove section
{% endcomment %}

{% if section.settings.enabled %}
<div class="sl-promo-banner" style="background: {{ section.settings.bg_color }};">
  <div class="sl-promo-banner-inner">

    {%- if section.settings.icon != blank -%}
      <span class="sl-promo-icon">{{ section.settings.icon }}</span>
    {%- endif -%}

    <p class="sl-promo-text" style="color: {{ section.settings.text_color }};">
      {{ section.settings.promo_text }}
    </p>

    {%- if section.settings.btn_label != blank and section.settings.btn_url != blank -%}
      <a href="{{ section.settings.btn_url }}"
         class="sl-promo-btn"
         style="color: {{ section.settings.btn_text_color }}; border-color: {{ section.settings.btn_text_color }};">
        {{ section.settings.btn_label }}
      </a>
    {%- endif -%}

  </div>
</div>
{% endif %}

<style>
  .sl-promo-banner {
    width: 100%;
    padding: 14px 24px;
    text-align: center;
  }
  .sl-promo-banner-inner {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }
  .sl-promo-icon {
    font-size: 18px;
    flex-shrink: 0;
  }
  .sl-promo-text {
    font-family: 'Jost', sans-serif;
    font-size: 13px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin: 0;
    line-height: 1.5;
  }
  .sl-promo-btn {
    font-family: 'Jost', sans-serif;
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    text-decoration: none;
    border: 1px solid;
    padding: 6px 16px;
    flex-shrink: 0;
    transition: opacity 0.2s;
    white-space: nowrap;
  }
  .sl-promo-btn:hover { opacity: 0.7; }

  @media (max-width: 768px) {
    .sl-promo-banner { padding: 12px 16px; }
    .sl-promo-text { font-size: 11px; letter-spacing: 1px; }
  }
</style>

{% schema %}
{
  "name": "SL Promo Banner",
  "settings": [
    {
      "type": "checkbox",
      "id": "enabled",
      "label": "Show Promo Banner",
      "default": true,
      "info": "Uncheck to hide the banner without removing the section"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "icon",
      "label": "Icon / Emoji (optional)",
      "default": "✦",
      "info": "Use any symbol or emoji — ✦ ◈ 🎁 💫 ⚡"
    },
    {
      "type": "text",
      "id": "promo_text",
      "label": "Promo Message",
      "default": "Limited Time Offer — Use code FIRST10 for 10% off your first order"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button Label (optional)",
      "default": "Shop Now",
      "info": "Leave blank to hide the button"
    },
    {
      "type": "url",
      "id": "btn_url",
      "label": "Button URL",
      "info": "Where the button links to"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#9a6358"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#f0eae0"
    },
    {
      "type": "color",
      "id": "btn_text_color",
      "label": "Button Color",
      "default": "#f0eae0"
    }
  ],
  "presets": [
    {
      "name": "SL Promo Banner"
    }
  ]
}
{% endschema %}
