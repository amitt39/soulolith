{% comment %}
Soulolith — Shop by Intention
File: sections/sl-shop-by-intention.liquid
{% endcomment %}

{% comment %}
<section class="sl-section sl-intention-section">
  <div class="sl-container">
    
  <div class="sl-section-header">
    <span class="sl-eyebrow">{{ section.settings.eyebrow | default: 'Curated for Your Journey' }}</span>
    <h2 class="sl-section-title">{{ section.settings.heading | default: 'Shop by <em>Intention</em>' }}</h2>
    <div class="sl-divider"></div>
  </div>
  
  <div class="sl-intention-grid">
    {%- for block in section.blocks -%}
      <a href="{{ block.settings.url | default: routes.collections_url | append: '/all' }}"
      class="sl-intention-card"
      {% if block.settings.image != blank %}
        style="--intention-bg: url('{{ block.settings.image | image_url: width: 800 }}')"
      {% endif %}
      {{ block.shopify_attributes }}>
      <div class="sl-intention-card-inner">
        <div class="sl-intention-icon">{{ block.settings.icon }}</div>
        <h3 class="sl-intention-title">{{ block.settings.title }}</h3>
        <p class="sl-intention-crystals">{{ block.settings.crystals }}</p>
        <p class="sl-intention-desc">{{ block.settings.description }}</p>
        <span class="sl-intention-link">Shop Now →</span>
      </div>
    </a>
  {%- else -%}
    <a href="{{ routes.collections_url }}/love" class="sl-intention-card">
    <div class="sl-intention-card-inner">
      <div class="sl-intention-icon">♡</div>
      <h3 class="sl-intention-title">Love</h3>
      <p class="sl-intention-crystals">Rose Quartz · Rhodonite</p>
      <p class="sl-intention-desc">Open your heart chakra and invite unconditional love.</p>
      <span class="sl-intention-link">Shop Now →</span>
    </div>
  </a>
  <a href="{{ routes.collections_url }}/protection" class="sl-intention-card">
  <div class="sl-intention-card-inner">
    <div class="sl-intention-icon">◎</div>
    <h3 class="sl-intention-title">Protection</h3>
    <p class="sl-intention-crystals">Black Tourmaline · Obsidian</p>
    <p class="sl-intention-desc">Shield your energy field from negativity and harm.</p>
    <span class="sl-intention-link">Shop Now →</span>
  </div>
</a>
<a href="{{ routes.collections_url }}/abundance" class="sl-intention-card">
<div class="sl-intention-card-inner">
  <div class="sl-intention-icon">✦</div>
  <h3 class="sl-intention-title">Abundance</h3>
  <p class="sl-intention-crystals">Citrine · Green Aventurine</p>
  <p class="sl-intention-desc">Attract wealth, prosperity, success, and growth.</p>
  <span class="sl-intention-link">Shop Now →</span>
</div>
</a>
<a href="{{ routes.collections_url }}/healing" class="sl-intention-card">
<div class="sl-intention-card-inner">
  <div class="sl-intention-icon">≈</div>
  <h3 class="sl-intention-title">Healing</h3>
  <p class="sl-intention-crystals">Amethyst · Clear Quartz</p>
  <p class="sl-intention-desc">Restore your balance and cleanse your spiritual body.</p>
  <span class="sl-intention-link">Shop Now →</span>
</div>
</a>
{%- endfor -%}
</div>

</div>
</section>

{% schema %}
{
  "name": "SL Shop by Intention",
  "tag": "div",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow Text", "default": "Curated for Your Journey" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop by Intention" }
  ],
  "blocks": [
    {
      "type": "intention",
      "name": "Intention Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Background Image" },
        { "type": "text", "id": "icon", "label": "Icon Symbol", "default": "♡" },
        { "type": "text", "id": "title", "label": "Intention Title", "default": "Love" },
        { "type": "text", "id": "crystals", "label": "Crystal Names", "default": "Rose Quartz · Rhodonite" },
        { "type": "text", "id": "description", "label": "Description", "default": "Open your heart chakra and invite unconditional love." },
        { "type": "url", "id": "url", "label": "Link URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "SL Shop by Intention",
      "blocks": [
        { "type": "intention", "settings": { "icon": "♡", "title": "Love", "crystals": "Rose Quartz · Rhodonite", "description": "Open your heart chakra and invite unconditional love." } },
        { "type": "intention", "settings": { "icon": "◎", "title": "Protection", "crystals": "Black Tourmaline · Obsidian", "description": "Shield your energy field from negativity and harm." } },
        { "type": "intention", "settings": { "icon": "✦", "title": "Abundance", "crystals": "Citrine · Green Aventurine", "description": "Attract wealth, prosperity, success, and growth." } },
        { "type": "intention", "settings": { "icon": "≈", "title": "Healing", "crystals": "Amethyst · Clear Quartz", "description": "Restore your balance and cleanse your spiritual body." } }
      ]
    }
  ]
}
{% endschema %}
{% endcomment %}